{
  "name": "hookmate",
  "version": "0.5.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./abi": {
      "types": "./dist/abi/index.d.ts",
      "import": "./dist/abi/index.mjs",
      "require": "./dist/abi/index.cjs"
    }
  },
  "files": [
    "dist",
    "src.ts",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/akshatmittal/hookmate.git"
  },
  "author": "Akshat Mittal <hi@akshatmittal.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepublishOnly": "pnpm build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.27.8",
    "@uniswap/v4-core": "^1.0.2",
    "@uniswap/v4-periphery": "^1.0.2",
    "forge-std": "github:foundry-rs/forge-std#v1.12.0",
    "tsdown": "^0.20.1",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "viem": "^2.45.0"
  },
  "packageManager": "pnpm@10.28.1"
}
